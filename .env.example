# Copy this file to `.env` and adjust as needed. All values are optional.

# Routing backend: "mock" (default, offline) or "free" (Nominatim + OSRM).
# The "free" stack is wired up in steps 1b/1c — leave as "mock" until then.
VITE_ROUTING_PROVIDER=mock

# Optional MapTiler key for nicer map tiles. Leave blank to use plain OSM tiles.
VITE_MAPTILER_KEY=
