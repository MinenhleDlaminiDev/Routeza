# Copy this file to `.env` and adjust as needed. All values are optional.

# Routing backend: "free" (default — real Nominatim + OSRM) or "mock" (fast
# offline demo with fake positions).
VITE_ROUTING_PROVIDER=free

# Optional MapTiler key for nicer map tiles. Leave blank to use plain OSM tiles.
VITE_MAPTILER_KEY=

# Supabase project (backend + accounts). Leave blank to run local-only.
# From your Supabase project: Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
